# ============================================================================
# Tugas Besar Big Data — environment template.
# Copy to .env and fill in real values:   Copy-Item .env.example .env
# The real .env is gitignored — never commit secrets (§11).
# ============================================================================

# --- FRED API (Dataset 2: Taiwan macro series) ---
# Get a free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# --- Kafka (extract stage) ---
# Host scripts use localhost:9092; in-container clients use kafka:19092.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- Cloud hosting (docker-compose.prod.yml only) ---
# The Oracle VM's PUBLIC IP. Used to advertise the Kafka EXTERNAL listener so
# remote clients connect. Leave blank for local-only runs (base compose file).
PUBLIC_IP=

# --- Spark cluster ---
SPARK_MASTER_URL=spark://localhost:7077

# --- Hive warehouse ---
HIVE_METASTORE_URI=thrift://localhost:9083
HIVESERVER2_HOST=localhost
HIVESERVER2_PORT=10000

# --- Postgres (Hive metastore backing DB; consumed by docker-compose.yml) ---
POSTGRES_USER=hive
POSTGRES_PASSWORD=hive
POSTGRES_DB=metastore
